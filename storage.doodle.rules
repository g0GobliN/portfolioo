rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Doodle images — anyone can read and upload drawings
    match /doodles/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
